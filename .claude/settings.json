{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Agent",
      "Bash"
    ],
    "ask": [
      "Bash(git reset --hard *)",
      "Bash(git clean *)",

      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(rm --recursive --force *)",
      "Bash(rm --force --recursive *)",

      "Bash(supabase db push *)",
      "Bash(supabase db reset *)",
      "Bash(supabase migration up *)",
      "Bash(supabase secrets set *)",
      "Bash(supabase link *)",

      "Bash(* drop table *)",
      "Bash(* DROP TABLE *)",
      "Bash(* truncate table *)",
      "Bash(* TRUNCATE TABLE *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(.claude/local-secrets.json)",
      "Read(**/.claude/local-secrets.json)",

      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(.claude/local-secrets.json)",
      "Edit(**/.claude/local-secrets.json)",

      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(.claude/local-secrets.json)",
      "Write(**/.claude/local-secrets.json)",

      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force *)",
      "Bash(git push * -f *)",
      "Bash(git push * --force-with-lease *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/lint-on-edit.sh\"",
            "statusMessage": "Linting edited file…"
          }
        ]
      }
    ]
  }
}
python3 - <<'PY'
import json
from pathlib import Path

settings = {
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Agent",

      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:e2e)",
      "Bash(npm run test:e2e:ui)",
      "Bash(npm run test:e2e:report)",
      "Bash(npm run test:visual)",
      "Bash(npm run supabase:start)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse *)"
    ],
    "ask": [
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm update)",
      "Bash(npm update *)",
      "Bash(npm run test:visual:update)",

      "Bash(npm run supabase:init)",
      "Bash(npm run supabase:login)",
      "Bash(npm run supabase:link)",
      "Bash(supabase link *)",
      "Bash(supabase db push *)",
      "Bash(supabase db reset *)",
      "Bash(supabase migration up *)",
      "Bash(supabase functions deploy *)",
      "Bash(supabase secrets set *)",

      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",

      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(rm --recursive --force *)",
      "Bash(rm --force --recursive *)",

      "Bash(vercel deploy *)",
      "Bash(vercel --prod *)",
      "Bash(wrangler deploy *)",

      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue create *)",

      "Bash(* drop table *)",
      "Bash(* DROP TABLE *)",
      "Bash(* truncate table *)",
      "Bash(* TRUNCATE TABLE *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(.claude/local-secrets.json)",
      "Read(**/.claude/local-secrets.json)",

      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.*.local)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "Edit(.claude/local-secrets.json)",
      "Edit(**/.claude/local-secrets.json)",

      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force *)",
      "Bash(git push * -f *)",
      "Bash(git push * --force-with-lease *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/lint-on-edit.sh\"",
            "statusMessage": "Linting edited file…"
          }
        ]
      }
    ]
  }
}

Path(".claude/settings.json").write_text(
    json.dumps(settings, indent=2, ensure_ascii=False) + "\n",
    encoding="utf-8",
)

# dependencies
node_modules/
pnpm-lock.yaml
yarn.lock

# build output
dist/

# env & local
.env
.env.*

# editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/

# Claude Code files. Project-level config (settings.json), guardrail skills, and
# hook scripts SHOULD be tracked; screenshots/notes/secrets stay local.
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/skills/**
!.claude/hooks/
!.claude/hooks/**
.claude/local-secrets.json
.claude/settings.local.json

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Session work products — screenshots, audit notes, scratch dirs. Kept
# locally for in-progress reference, never shipped to production.
.audit/
.audit-shots/
.tmp-screens/
audits/
consistency-audit.md

# Playwright E2E
/test-results/
/playwright-report/
/blob-report/
/e2e/.auth/
# pipeline run logs (regenerated each cron run; keep the dir, ignore the output)
logs/*
!logs/.gitkeep

# Track shared Claude rules
!.claude/rules/
!.claude/rules/**

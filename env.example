# FeelFlick — Environment Variable Template
# Copy this file to .env and fill in your values.
# cp env.example .env
#
# IMPORTANT: .env is gitignored and must never be committed.
# All VITE_* vars are bundled into the client — do NOT put server secrets here.
# The OpenAI API key must stay server-side (Supabase edge function secret).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL. Found in: Project Settings → API → Project URL.
# Non-secret — safe to expose in the client bundle (RLS enforces access control).
VITE_SUPABASE_URL=

# Your Supabase anon/public key. Found in: Project Settings → API → Project API keys → anon public.
# Safe client-side — Row Level Security restricts what unauthenticated users can access.
VITE_SUPABASE_ANON_KEY=

# ── TMDB ──────────────────────────────────────────────────────────────────────
# The Movie Database read-only API key. Get one at: https://www.themoviedb.org/settings/api
# Acceptable in the bundle — read-only, rate-limited to 40 req/10s.
VITE_TMDB_API_KEY=

# ── Sentry ────────────────────────────────────────────────────────────────────
# Sentry DSN for error monitoring (get from sentry.io/settings/projects/feelflick-app/keys/)
VITE_SENTRY_DSN=

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of Google OAuth email addresses that get /admin access.
# Example: admin@example.com,other@example.com
VITE_ADMIN_EMAILS=

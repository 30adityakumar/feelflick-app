{
  "name": "feelflick-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "supabase:init": "supabase init",
    "supabase:start": "supabase start",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=public --project=app",
    "test:e2e:ui": "playwright test --project=public --project=app --ui",
    "test:e2e:report": "playwright show-report",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:visual:app": "playwright test --project=visual-app",
    "test:visual:app:update": "playwright test --project=visual-app --update-snapshots",
    "test:visual:home": "playwright test --project=visual-app e2e/visual-auth/home.visual.js",
    "test:visual:home:update": "playwright test --project=visual-app e2e/visual-auth/home.visual.js --update-snapshots",
    "test:e2e:movie": "playwright test --project=app e2e/app/movie.e2e.js",
    "test:visual:movie": "playwright test --project=visual-app e2e/visual-auth/movie.visual.js",
    "test:visual:movie:update": "playwright test --project=visual-app e2e/visual-auth/movie.visual.js --update-snapshots",
    "test:e2e:library": "playwright test --project=app e2e/app/library.e2e.js",
    "test:visual:library": "playwright test --project=visual-app e2e/visual-auth/library.visual.js",
    "test:visual:library:update": "playwright test --project=visual-app e2e/visual-auth/library.visual.js --update-snapshots"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.56.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/edge": "^1.3.1",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "openai": "^6.42.0",
    "posthog-js": "^1.380.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "supabase": "^2.105.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.0"
  }
}

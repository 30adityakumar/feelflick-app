{
  "name": "feelflick-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "supabase:init": "supabase init",
    "supabase:start": "supabase start",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link",
    "persona:accounts:dry-run": "node scripts/personas/provision-persona-accounts.mjs --dry-run",
    "persona:accounts:provision": "node scripts/personas/provision-persona-accounts.mjs --apply",
    "persona:auth-states": "playwright test --project=persona-auth",
    "persona:auth-states:ui": "playwright test --project=persona-auth --ui",
    "persona:onboard": "playwright test --project=persona-onboarding",
    "persona:onboard:ui": "playwright test --project=persona-onboarding --ui",
    "persona:revisit": "playwright test --project=persona-revisit",
    "persona:revisit:ui": "playwright test --project=persona-revisit --ui",
    "persona:revisit:summary": "node scripts/personas/summarize-revisit-followups.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "guard:foundations": "node scripts/guards/legacy-gradient-guard.mjs && node scripts/guards/theme-audit.mjs",
    "guard:foundations:update": "node scripts/guards/legacy-gradient-guard.mjs --update-baseline",
    "audit:theme": "node scripts/guards/theme-audit.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=public --project=app",
    "test:e2e:ui": "playwright test --project=public --project=app --ui",
    "test:e2e:report": "playwright show-report",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:visual:app": "playwright test --project=visual-app",
    "test:visual:app:update": "playwright test --project=visual-app --update-snapshots",
    "test:visual:home": "playwright test --project=visual-app e2e/visual-auth/home.visual.js",
    "test:visual:home:update": "playwright test --project=visual-app e2e/visual-auth/home.visual.js --update-snapshots",
    "test:e2e:movie": "playwright test --project=app e2e/app/movie.e2e.js",
    "test:visual:movie": "playwright test --project=visual-app e2e/visual-auth/movie.visual.js",
    "test:visual:movie:update": "playwright test --project=visual-app e2e/visual-auth/movie.visual.js --update-snapshots",
    "test:e2e:library": "playwright test --project=app e2e/app/library.e2e.js",
    "test:visual:library": "playwright test --project=visual-app e2e/visual-auth/library.visual.js",
    "test:visual:library:update": "playwright test --project=visual-app e2e/visual-auth/library.visual.js --update-snapshots",
    "test:e2e:profile": "playwright test --project=app e2e/app/profile.e2e.js",
    "test:visual:profile": "playwright test --project=visual-app e2e/visual-auth/profile.visual.js",
    "test:visual:profile:update": "playwright test --project=visual-app e2e/visual-auth/profile.visual.js --update-snapshots",
    "test:e2e:people": "playwright test --project=app e2e/app/people.e2e.js",
    "test:visual:people": "playwright test --project=visual-app e2e/visual-auth/people.visual.js",
    "test:visual:people:update": "playwright test --project=visual-app e2e/visual-auth/people.visual.js --update-snapshots",
    "test:e2e:browse": "playwright test --project=app e2e/app/browse.e2e.js",
    "test:visual:browse": "playwright test --project=visual-app e2e/visual-auth/browse.visual.js",
    "test:visual:browse:update": "playwright test --project=visual-app e2e/visual-auth/browse.visual.js --update-snapshots",
    "test:e2e:discover": "playwright test --project=app e2e/app/discover.e2e.js",
    "test:visual:discover": "playwright test --project=visual-app e2e/visual-auth/discover.visual.js",
    "test:visual:discover:update": "playwright test --project=visual-app e2e/visual-auth/discover.visual.js --update-snapshots",
    "test:e2e:preferences": "playwright test --project=app e2e/app/preferences.e2e.js",
    "test:visual:preferences": "playwright test --project=visual-app e2e/visual-auth/preferences.visual.js",
    "test:visual:preferences:update": "playwright test --project=visual-app e2e/visual-auth/preferences.visual.js --update-snapshots"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.10",
    "@sentry/react": "^10.58.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/edge": "^1.3.1",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.21.0",
    "openai": "^6.44.0",
    "posthog-js": "^1.390.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.0"
  }
}
